---
// Gráfico decorativo do card de relatório — dá o traço de "instrumento de dados".
interface Props { kind: 'line' | 'area' | 'bars'; color?: string; }
const { kind, color = 'var(--green)' } = Astro.props;
---
<svg class="spark" viewBox="0 0 120 32" preserveAspectRatio="none" aria-hidden="true">
  {kind === 'line' && (
    <polyline points="0,28 20,25 40,20 60,18 80,10 100,7 120,3" fill="none" stroke={color} stroke-width="2" />
  )}
  {kind === 'area' && (
    <>
      <polyline points="0,28 20,23 40,24 60,15 80,12 100,7 120,4" fill="none" stroke={color} stroke-width="2" />
      <polygon points="0,32 0,28 20,23 40,24 60,15 80,12 100,7 120,4 120,32" fill={color} opacity="0.12" />
    </>
  )}
  {kind === 'bars' && (
    <g fill={color}>
      <rect x="6" y="16" width="14" height="16" /><rect x="30" y="10" width="14" height="22" />
      <rect x="54" y="19" width="14" height="13" /><rect x="78" y="6" width="14" height="26" />
      <rect x="102" y="12" width="14" height="20" />
    </g>
  )}
</svg>

<style>
  .spark{height:32px; width:100%; display:block}
</style>
