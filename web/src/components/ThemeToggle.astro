---
import Icon from './Icon.astro';
---
<button id="theme-toggle" type="button" aria-label="Alternar tema claro/escuro" title="Alternar tema">
  <span class="s"><Icon name="sun" size={16} /></span>
  <span class="m"><Icon name="moon" size={16} /></span>
</button>

<style>
  #theme-toggle{
    background:var(--surface); border:1px solid var(--line-strong); border-radius:8px;
    width:34px; height:34px; display:grid; place-items:center; cursor:pointer; color:var(--muted);
  }
  #theme-toggle:hover{color:var(--green); border-color:var(--green)}
  #theme-toggle .m{display:none}
  :root[data-theme="dark"] #theme-toggle .s{display:none}
  :root[data-theme="dark"] #theme-toggle .m{display:block}
  @media (prefers-color-scheme:dark){
    :root:not([data-theme="light"]) #theme-toggle .s{display:none}
    :root:not([data-theme="light"]) #theme-toggle .m{display:block}
  }
</style>

<script>
  const root = document.documentElement;
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const cur = root.getAttribute('data-theme')
      || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    const next = cur === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    try { localStorage.setItem('dppge-theme', next); } catch {}
  });
</script>
