---
import Base from './Base.astro';
import Icon from '../components/Icon.astro';
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  section: { label: string; href: string };
  headings?: MarkdownHeading[];
  editPath?: string;   // caminho relativo dentro de docs/ p/ "editar no GitHub"
  meta?: string;       // linha mono opcional (data, status…)
  description?: string;
}
const { title, section, headings = [], editPath, meta, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const editUrl = editPath ? `https://github.com/ifesserra-lab/diretoria/edit/master/docs/${editPath}` : null;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---
<Base title={title} description={description}>
  <div class="wrap doc-wrap">
    <article class="doc">
      <nav class="crumb mono" aria-label="Trilha">
        <a href={base + '/'}>Início</a> <span>/</span>
        <a href={base + section.href}>{section.label}</a>
      </nav>
      <header class="doc-head">
        <h1>{title}</h1>
        {meta && <p class="meta mono">{meta}</p>}
      </header>
      <div class="prose"><slot /></div>
      {editUrl && (
        <footer class="doc-foot">
          <a href={editUrl} class="edit"><Icon name="external" size={14} /> Editar esta página no GitHub</a>
        </footer>
      )}
    </article>

    {toc.length > 0 && (
      <aside class="toc" aria-label="Nesta página">
        <div class="toc-t mono">Nesta página</div>
        <ul>
          {toc.map((h) => (
            <li class={h.depth === 3 ? 'sub' : ''}><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ul>
      </aside>
    )}
  </div>
</Base>

<style>
  .doc-wrap{display:grid; grid-template-columns:minmax(0,1fr) 220px; gap:48px; padding:44px 24px 20px; align-items:start}
  .doc{min-width:0; max-width:none}
  .crumb{font-size:12px; color:var(--faint); display:flex; gap:8px; margin-bottom:14px}
  .crumb a{color:var(--muted)}
  .crumb span{color:var(--line-strong)}
  .doc-head{border-bottom:1px solid var(--line); padding-bottom:20px; margin-bottom:28px}
  .doc-head h1{font-size:clamp(28px,4vw,42px)}
  .doc-head .meta{color:var(--gold); font-size:12.5px; margin-top:10px}

  .toc{position:sticky; top:84px; font-size:13px}
  .toc-t{font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:var(--faint); margin-bottom:10px}
  .toc ul{list-style:none; margin:0; padding:0; border-left:1px solid var(--line); display:flex; flex-direction:column; gap:8px}
  .toc li{padding-left:14px}
  .toc li.sub{padding-left:26px; font-size:12.5px}
  .toc a{color:var(--muted)}
  .toc a:hover{color:var(--green)}
  @media (max-width:900px){ .doc-wrap{grid-template-columns:1fr} .toc{display:none} }

  .doc-foot{margin-top:40px; padding-top:20px; border-top:1px solid var(--line)}
  .edit{font-family:var(--mono); font-size:13px; display:inline-flex; gap:7px; align-items:center; color:var(--muted)}
  .edit:hover{color:var(--green)}
</style>

<!-- estilos da prosa (conteúdo Markdown renderizado) -->
<style is:global>
  .prose{font-size:17px; line-height:1.72; color:var(--ink)}
  /* o título já é exibido no cabeçalho do Doc — esconde o H1 duplicado do corpo */
  .prose > h1:first-child{display:none}
  .prose > * + *{margin-top:1.1em}
  .prose h2{font-size:26px; margin-top:2em; scroll-margin-top:84px}
  .prose h3{font-size:20px; margin-top:1.6em; scroll-margin-top:84px}
  .prose h2, .prose h3{padding-bottom:0}
  .prose p{color:var(--ink)}
  .prose a{color:var(--green); text-decoration:underline; text-underline-offset:2px}
  .prose strong{font-weight:700}
  .prose ul, .prose ol{padding-left:1.4em; display:flex; flex-direction:column; gap:.4em}
  .prose li{padding-left:.2em}
  .prose blockquote{border-left:3px solid var(--gold); padding:2px 0 2px 16px; color:var(--muted); font-style:italic}
  .prose hr{border:0; border-top:1px solid var(--line); margin:2em 0}
  .prose code{font-family:var(--mono); font-size:.86em; background:var(--surface-2); border:1px solid var(--line);
    border-radius:5px; padding:1px 6px}
  .prose pre{background:var(--surface-2); border:1px solid var(--line); border-radius:10px; padding:16px 18px; overflow-x:auto}
  .prose pre code{background:none; border:0; padding:0; font-size:13.5px}
  .prose table{width:100%; border-collapse:collapse; font-size:15px; display:block; overflow-x:auto}
  .prose th, .prose td{text-align:left; padding:10px 14px; border-bottom:1px solid var(--line); vertical-align:top}
  .prose th{font-family:var(--mono); font-size:11.5px; text-transform:uppercase; letter-spacing:.05em; color:var(--faint);
    background:var(--surface-2); font-weight:600}
  .prose img{border-radius:10px; border:1px solid var(--line)}
  .prose .mermaid{background:var(--surface); border:1px solid var(--line); border-radius:10px; padding:16px; text-align:center}
</style>

<!-- Mermaid client-side (substitui o plugin mermaid2 do MkDocs).
     Só carrega a lib se a página tiver algum bloco ```mermaid. -->
<script>
  const blocks = Array.from(document.querySelectorAll('pre > code.language-mermaid'));
  if (blocks.length) {
    const dark = document.documentElement.getAttribute('data-theme') === 'dark'
      || (!document.documentElement.getAttribute('data-theme')
          && matchMedia('(prefers-color-scheme: dark)').matches);
    const { default: mermaid } = await import('mermaid');
    mermaid.initialize({ startOnLoad: false, theme: dark ? 'dark' : 'neutral', securityLevel: 'strict' });
    for (let i = 0; i < blocks.length; i++) {
      const code = blocks[i].textContent || '';
      try {
        const { svg } = await mermaid.render('mmd-' + i, code);
        const el = document.createElement('div');
        el.className = 'mermaid';
        el.innerHTML = svg;
        blocks[i].parentElement?.replaceWith(el);
      } catch (e) { /* mantém o bloco de código se falhar */ }
    }
  }
</script>
