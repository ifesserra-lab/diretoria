---
import Base from '../layouts/Base.astro';
import GitStrip from '../components/GitStrip.astro';
import QuickCard from '../components/QuickCard.astro';
import StatStrip from '../components/StatStrip.astro';
import ReportCard from '../components/ReportCard.astro';
import Icon from '../components/Icon.astro';
import { reports } from '../lib/reports';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const destaques = reports.filter((r) => r.destaque);
const team = [
  { nome: 'Paulo Sérgio Jr.', papel: 'Diretor', area: 'Geral' },
  { nome: 'Richard Godinez', papel: 'Coordenador', area: 'Pesquisa' },
  { nome: 'Celio Maioli', papel: 'Coordenador', area: 'Extensão' },
  { nome: 'Julia', papel: 'Técnica', area: 'Apoio' },
];
const quick = [
  { icon:'atas', titulo:'Atas', desc:'Registros deliberativos das reuniões', meta:'últ. 2026-03-12 · reunião geral', href:base+'/atas' },
  { icon:'decisoes', titulo:'Decisões', desc:'Diretrizes formalizadas em ADR', meta:'#001 · planejamento DPPGE', href:base+'/decisoes' },
  { icon:'reports', titulo:'Relatórios', desc:'Painéis analíticos de impacto', meta:reports.length+' painéis · ROI, egressos, captação', href:base+'/relatorios' },
  { icon:'comissoes', titulo:'Comissões', desc:'Frentes de trabalho do campus', meta:'energia · labs · SBF · SNCT', href:base+'/comissoes' },
  { icon:'pautas', titulo:'Pautas', desc:'Calendário 2026 · reuniões quinzenais', meta:'sextas-feiras', href:base+'/pautas' },
  { icon:'processos', titulo:'Processos', desc:'Editais e acordos de PD&I', meta:'FAPES · patrocínio · NIT', href:base+'/processos' },
];
---
<Base>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap inner">
      <p class="eyebrow green">Fonte única de verdade</p>
      <h1>Toda decisão da diretoria tem uma origem rastreável.</h1>
      <p class="sub">Atas, diretrizes e indicadores da pesquisa, pós-graduação e extensão do
        IFES Campus Serra — versionados no Git, públicos e auditáveis.</p>
      <div class="btns">
        <a class="btn primary" href={base + '/relatorios'}>Ver relatórios <Icon name="arrow" size={16} /></a>
        <a class="btn ghost" href={base + '/decisoes'}>Últimas decisões</a>
      </div>
    </div>
  </section>

  <div class="wrap stack">
    <GitStrip />

    <!-- ACESSO RÁPIDO -->
    <div class="qgrid">
      {quick.map((q) => <QuickCard {...q} />)}
    </div>

    <StatStrip />

    <!-- RELATÓRIOS EM DESTAQUE -->
    <section class="block">
      <div class="bh">
        <div>
          <p class="eyebrow">Impacto em números</p>
          <h2>Relatórios em destaque</h2>
        </div>
        <a class="all" href={base + '/relatorios'}>Ver os {reports.length} <Icon name="arrow" size={14} /></a>
      </div>
      <div class="rgrid">
        {destaques.map((r) => <ReportCard report={r} />)}
      </div>
    </section>

    <!-- EQUIPE -->
    <section class="block">
      <div class="bh">
        <div>
          <p class="eyebrow">Quem responde</p>
          <h2>Equipe gestora</h2>
        </div>
        <a class="all" href={base + '/equipe'}>Ver equipe e comissões <Icon name="arrow" size={14} /></a>
      </div>
      <div class="tgrid">
        {team.map((t) => (
          <div class="tcard">
            <span class="av">{t.nome.split(' ').map((w) => w[0]).slice(0,2).join('')}</span>
            <span class="tn">{t.nome}</span>
            <span class="tr mono">{t.papel} · {t.area}</span>
          </div>
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .hero{position:relative; overflow:hidden; border-bottom:1px solid var(--line)}
  .hero:before{content:''; position:absolute; inset:0; pointer-events:none;
    background:radial-gradient(120% 100% at 88% -20%, var(--green-soft) 0%, transparent 55%)}
  .hero .inner{position:relative; padding:72px 24px 60px; max-width:760px}
  .hero h1{font-size:clamp(34px,5.6vw,60px); margin-top:16px; letter-spacing:-.018em}
  .hero .sub{font-size:19px; color:var(--muted); margin-top:20px; max-width:600px; line-height:1.55}
  .btns{display:flex; gap:12px; margin-top:30px; flex-wrap:wrap}

  .stack{display:flex; flex-direction:column; gap:44px; padding-top:40px; padding-bottom:20px}
  .qgrid{display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--line);
    border:1px solid var(--line); border-radius:14px; overflow:hidden}
  @media (max-width:820px){ .qgrid{grid-template-columns:1fr 1fr} }
  @media (max-width:480px){ .qgrid{grid-template-columns:1fr} }

  .block{display:flex; flex-direction:column; gap:18px}
  .bh{display:flex; align-items:flex-end; justify-content:space-between; gap:16px}
  .bh h2{font-size:clamp(24px,3vw,32px); margin-top:6px}
  .all{font-family:var(--mono); font-size:13px; font-weight:600; color:var(--green); display:inline-flex; gap:6px; align-items:center; white-space:nowrap}
  .rgrid{display:grid; grid-template-columns:repeat(3,1fr); gap:16px}
  @media (max-width:820px){ .rgrid{grid-template-columns:1fr} }

  .tgrid{display:grid; grid-template-columns:repeat(4,1fr); gap:14px}
  @media (max-width:820px){ .tgrid{grid-template-columns:1fr 1fr} }
  .tcard{border:1px solid var(--line); border-radius:12px; background:var(--surface); padding:20px; display:flex; flex-direction:column; gap:6px}
  .av{width:44px; height:44px; border-radius:50%; background:var(--green-soft); color:var(--green-deep);
    display:grid; place-items:center; font-family:var(--serif); font-weight:700; font-size:16px; margin-bottom:6px}
  .tn{font-family:var(--serif); font-size:17px; font-weight:600}
  .tr{font-size:12px; color:var(--muted)}
  @media (prefers-color-scheme:dark){ :root:not([data-theme="light"]) .av{color:var(--green)} }
  :root[data-theme="dark"] .av{color:var(--green)}
</style>
