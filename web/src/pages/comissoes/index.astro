---
import Base from '../../layouts/Base.astro';
import DocList from '../../components/DocList.astro';
import { getCollection } from 'astro:content';
import { sections } from '../../lib/sections';
const s = sections.comissoes;
const entries = await getCollection('comissoes');
---
<Base title={s.label} description={s.intro}>
  <section class="section"><div class="wrap">
    <div class="sec-head narrow"><p class="eyebrow">Frentes de trabalho</p><h1>{s.label}</h1><p class="lead">{s.intro}</p></div>
    <DocList section={s} entries={entries} />
  </div></section>
</Base>
