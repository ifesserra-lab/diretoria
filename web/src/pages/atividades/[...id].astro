---
import Doc from '../../layouts/Doc.astro';
import { getCollection, render } from 'astro:content';
import { sections } from '../../lib/sections';
import { displayTitle, dateFromId, fmtMonth } from '../../lib/derive';
export async function getStaticPaths() {
  const entries = await getCollection('atividades');
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}
const { entry } = Astro.props;
const s = sections.atividades;
const { Content, headings } = await render(entry);
const titulo = displayTitle(entry as any);
const data = dateFromId(entry.id);
---
<Doc title={titulo} section={{ label: s.label, href: s.href }} headings={headings}
     editPath={`${s.editDir}/${entry.id}.md`} meta={data ? fmtMonth(data) : undefined}>
  <Content />
</Doc>
