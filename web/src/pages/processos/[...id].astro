---
import Doc from '../../layouts/Doc.astro';
import { getCollection, render } from 'astro:content';
import { sections } from '../../lib/sections';
import { displayTitle } from '../../lib/derive';
export async function getStaticPaths() {
  const entries = await getCollection('processos');
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}
const { entry } = Astro.props;
const s = sections.processos;
const { Content, headings } = await render(entry);
const titulo = displayTitle(entry as any);
---
<Doc title={titulo} section={{ label: s.label, href: s.href }} headings={headings}
     editPath={`${s.editDir}/${entry.id}.md`}>
  <Content />
</Doc>
